# Quick run commands (Windows)
# 1) Activate virtual environment
venv\Scripts\Activate.ps1   # PowerShell
venv\Scripts\activate       # CMD

# 2) Install dependencies (first time / after changes)
.\venv\Scripts\python.exe -m pip install --upgrade pip
.\venv\Scripts\python.exe -m pip install -r agrosense_backend\requirements.txt
.\venv\Scripts\python.exe -m pip install django-cors-headers

# 3) Migrate DB and start server
cd agrosense_backend
..\venv\Scripts\python.exe manage.py migrate
..\venv\Scripts\python.exe manage.py runserver 127.0.0.1:8000 --noreload

#for frontend
cd ..
.\venv\Scripts\python.exe -m http.server 3000
http://localhost:3000/frontend_new/home.html

# quick one-command startup scripts (from project root)
.\start_backend.ps1
.\start_frontend.ps1
.\start_dev.ps1

